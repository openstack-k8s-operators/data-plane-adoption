    edpmNeutronOvnAgentImage: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-neutron-ovn-agent{{ container_suffix }}:{{ container_tag }}
    edpmNeutronSriovAgentImage: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-neutron-sriov-agent{{ container_suffix }}:{{ container_tag }}
