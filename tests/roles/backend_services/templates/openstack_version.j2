    ovnControllerOvsImage: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-ovn-base{{ container_suffix }}:{{ container_tag }}
    ovnNbDbclusterImage: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-ovn-nb-db-server{{ container_suffix }}:{{ container_tag }}
    ovnNorthdImage: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-ovn-northd{{ container_suffix }}:{{ container_tag }}
