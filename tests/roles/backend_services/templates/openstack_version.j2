    rabbitmqImage: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-rabbitmq{{ container_suffix }}:{{ container_tag }}
    swiftAccountImage: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-swift-account{{ container_suffix }}:{{ container_tag }}
    swiftContainerImage: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-swift-container{{ container_suffix }}:{{ container_tag }}
    swiftObjectImage: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-swift-object{{ container_suffix }}:{{ container_tag }}
    swiftProxyImage: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-swift-proxy-server{{ container_suffix }}:{{ container_tag }}
{% if (backend_services_cindervolumes | length > 0  or
       (backend_services_cindervolumes_extraimages is defined and backend_services_cindervolumes_extraimages is mapping)) %}
    cinderVolumeImages:
{% endif %}
{% if backend_services_cindervolumes | length > 0 %}
{% for _vol in backend_services_cindervolumes %}
      {{ _vol }}: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-cinder-volume{{ container_suffix }}:{{ container_tag }}
{% endfor %}
{% endif %}
{% if (backend_services_cindervolumes_extraimages is defined and backend_services_cindervolumes_extraimages is mapping) %}
{% for _container_name, _container_uri in backend_services_cindervolumes_extraimages.items() %}
      {{ _container_name }}: {{ _container_uri }}
{% endfor %}
{% endif %}
{% if (backend_services_manilashares | length > 0  or
       (backend_services_manilashares_extraimages is defined and backend_services_manilashares_extraimages is mapping)) %}
    manilaShareImages:
{% endif %}
{% if backend_services_manilashares | length > 0 %}
{% for _vol in backend_services_manilashares %}
      {{ _vol }}: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-manila-share{{ container_suffix }}:{{ container_tag }}
{% endfor %}
{% endif %}
{% if (backend_services_manilashares_extraimages is defined and backend_services_manilashares_extraimages is mapping) %}
{% for _container_name, _container_uri in backend_services_manilashares_extraimages.items() %}
      {{ _container_name }}: {{ _container_uri }}
{% endfor %}
{% endif %}
