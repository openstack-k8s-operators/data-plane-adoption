    novaAPIImage: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-nova-api{{ container_suffix }}:{{ container_tag }}
    novaComputeImage: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-nova-compute{{ container_suffix }}:{{ container_tag }}
    novaConductorImage: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-nova-conductor{{ container_suffix }}:{{ container_tag }}
    novaNovncImage: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-nova-novncproxy{{ container_suffix }}:{{ container_tag }}
    novaSchedulerImage: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-nova-scheduler{{ container_suffix }}:{{ container_tag }}
    octaviaAPIImage: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-octavia-api{{ container_suffix }}:{{ container_tag }}
