    manilaAPIImage: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-manila-api{{ container_suffix }}:{{ container_tag }}
    manilaSchedulerImage: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-manila-scheduler{{ container_suffix }}:{{ container_tag }}
    manilaShareImage: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-manila-share{{ container_suffix }}:{{ container_tag }}
    mariadbImage: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-mariadb{{ container_suffix }}:{{ container_tag }}
