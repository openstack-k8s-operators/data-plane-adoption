    infraMemcachedImage: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-memcached{{ container_suffix }}:{{ container_tag }}
    ironicAPIImage: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-ironic-api{{ container_suffix }}:{{ container_tag }}
    ironicConductorImage: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-ironic-conductor{{ container_suffix }}:{{ container_tag }}
    ironicInspectorImage: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-ironic-inspector{{ container_suffix }}:{{ container_tag }}
    ironicNeutronAgentImage: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-ironic-neutron-agent{{ container_suffix }}:{{ container_tag }}
    ironicPxeImage: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}openstack-ironic-pxe{{ container_suffix }}:{{ container_tag }}
    ironicPythonAgentImage: {{ container_registry }}/{{ container_namespace }}/{{ container_prefix }}ironic-python-agent{{ container_suffix }}:{{ container_tag }}
