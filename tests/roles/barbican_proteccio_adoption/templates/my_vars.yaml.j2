# Source environment connection variables
# Generated by barbican_proteccio_adoption Ansible role

UC_HOST: "{{ source_undercloud_host }}"
CTRL_HOST: "{{ source_controller_host }}"
controller1_ssh: "sudo ssh -t {{ source_undercloud_host }} 'sudo -u stack ssh -t tripleo-admin@{{ source_controller_host }} bash -lc'"
undercloud_ssh: "sudo ssh -t {{ source_undercloud_host }} 'sudo -u stack bash -lc'"
tripleo_passwords:
  default: "{{ tripleo_passwords_file | default('/home/' + ansible_user + '/real-overcloud-passwords.yaml') }}"
